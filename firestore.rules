rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny Catch-All Guard
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getIncomingData() {
      return request.resource.data;
    }

    function getExistingData() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Transaction Validation Blueprint
    function isValidTransaction(tx) {
      return tx.id is string && tx.id.size() <= 100
        && tx.amount is number && tx.amount > 0
        && tx.description is string && tx.description.size() <= 200
        && tx.category is string && tx.category.size() <= 100
        && tx.type is string && (tx.type == 'income' || tx.type == 'expense')
        && tx.date is string && tx.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && tx.createdAt is int
        && tx.familyCode is string && tx.familyCode.size() <= 100 && tx.familyCode.matches('^[a-zA-Z0-9_\\-]+$')
        && tx.createdByUser is string && tx.createdByUser.size() <= 100;
    }

    // User Profile Validation Blueprint
    function isValidUser(user) {
      return user.id is string && user.id.size() <= 128
        && user.displayName is string && user.displayName.size() <= 100
        && user.familyCode is string && user.familyCode.size() <= 100 && user.familyCode.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Transactions Rules Engine
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && isValidId(transactionId) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyCode == getExistingData().familyCode
      );

      allow list: if isSignedIn() && (
        // Secures matching range queries: client must query by where('familyCode', '==', userFamilyCode)
        resource.data.familyCode == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyCode
      );

      allow create: if isSignedIn() 
        && isValidId(transactionId)
        && isValidTransaction(getIncomingData())
        && getIncomingData().familyCode == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyCode;

      allow update: if false; // Transactions are immutable for perfect ledger records

      allow delete: if isSignedIn() 
        && isValidId(transactionId)
        && getExistingData().familyCode == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyCode;
    }

    // User Profiles Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false;

      allow create, update: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(getIncomingData());
    }
  }
}
